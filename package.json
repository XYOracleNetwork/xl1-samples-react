  "version": "1.0.0",
  "description": "XYO Layer One Protocol Sample Code",
  "homepage": "https://xyo.network",
  "bugs": {
    "url": "git+https://github.com/XYOracleNetwork/xl1-protocol-samples/issues",
    "email": "support@xylabs.com"
  },
